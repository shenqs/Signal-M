<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/primary_text"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/subtitle"
                android:textSize="14sp"
                android:textColor="@color/secondary_text"
                android:layout_marginBottom="20dp" />

            <!-- WiFi信号卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/wifiCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_wifi"
                            app:tint="@color/primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/wifi_signal"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_text"
                            android:layout_marginStart="10dp" />

                        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                        <TextView
                            android:id="@+id/wifiStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/disconnected"
                            android:textSize="13sp"
                            android:textColor="@color/secondary_text" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/wifiStrength"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="-- dBm"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_text" />

                        <com.signalmontor.app.view.AnimatedSignalBarView
                            android:id="@+id/wifiBars"
                            android:layout_width="48dp"
                            android:layout_height="36dp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/wifiDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/not_available"
                        android:textSize="12sp"
                        android:textColor="@color/secondary_text" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginTop="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/radiation_level"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_text"
                        android:layout_marginTop="10dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp"
                        android:gravity="center_vertical">

                        <com.signalmontor.app.view.RadiationGaugeView
                            android:id="@+id/wifiRadiationGauge"
                            android:layout_width="80dp"
                            android:layout_height="80dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:id="@+id/wifiRadiationLevel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/wifiSAR"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SAR: -- W/kg"
                                android:textSize="12sp"
                                android:textColor="@color/secondary_text"
                                android:layout_marginTop="2dp" />

                            <TextView
                                android:id="@+id/wifiPercentOfLimit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="占限值: --%"
                                android:textSize="12sp"
                                android:textColor="@color/secondary_text" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/wifiRecommendation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/not_available"
                        android:textSize="12sp"
                        android:textColor="@color/secondary_text" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 蜂窝网络信号卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cellularCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_cellular"
                            app:tint="@color/primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cellular_signal"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_text"
                            android:layout_marginStart="10dp" />

                        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                        <TextView
                            android:id="@+id/cellularNetworkType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/cellularStrength"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="-- dBm"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_text" />

                        <com.signalmontor.app.view.AnimatedSignalBarView
                            android:id="@+id/cellularBars"
                            android:layout_width="48dp"
                            android:layout_height="36dp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/cellularDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/not_available"
                        android:textSize="12sp"
                        android:textColor="@color/secondary_text" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginTop="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/radiation_level"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_text"
                        android:layout_marginTop="10dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp"
                        android:gravity="center_vertical">

                        <com.signalmontor.app.view.RadiationGaugeView
                            android:id="@+id/cellularRadiationGauge"
                            android:layout_width="80dp"
                            android:layout_height="80dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:id="@+id/cellularRadiationLevel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/cellularSAR"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SAR: -- W/kg"
                                android:textSize="12sp"
                                android:textColor="@color/secondary_text"
                                android:layout_marginTop="2dp" />

                            <TextView
                                android:id="@+id/cellularPercentOfLimit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="占限值: --%"
                                android:textSize="12sp"
                                android:textColor="@color/secondary_text" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/cellularRecommendation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/not_available"
                        android:textSize="12sp"
                        android:textColor="@color/secondary_text" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 卫星定位信息卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/satelliteCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_satellite"
                            app:tint="@color/primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="卫星定位 (GPS/北斗)"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_text"
                            android:layout_marginStart="10dp" />
                    </LinearLayout>

                    <!-- 3D卫星地球视图 -->
                    <com.signalmontor.app.view.Satellite3DView
                        android:id="@+id/satellite3DView"
                        android:layout_width="match_parent"
                        android:layout_height="280dp"
                        android:layout_marginTop="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/gpsCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="#2196F3" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="GPS"
                                android:textSize="12sp"
                                android:textColor="@color/secondary_text" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/beidouCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="#F44336" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="北斗"
                                android:textSize="12sp"
                                android:textColor="@color/secondary_text" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/glonassCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="#4CAF50" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="GLONASS"
                                android:textSize="12sp"
                                android:textColor="@color/secondary_text" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/galileoCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="#FF9800" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Galileo"
                                android:textSize="12sp"
                                android:textColor="@color/secondary_text" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/totalSatellites"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary_text" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="总计"
                                android:textSize="12sp"
                                android:textColor="@color/secondary_text" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginTop="12dp" />

                    <!-- 定位来源标识 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/gnssBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🛰️ 真实卫星信号"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:visibility="gone"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/assistedBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🌐 辅助定位已启用"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </LinearLayout>

                    <!-- 定位来源列表 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="定位来源"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_text"
                        android:layout_marginTop="10dp" />

                    <LinearLayout
                        android:id="@+id/positionSourceContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="6dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginTop="10dp" />

                    <TextView
                        android:id="@+id/locationInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="等待定位..."
                        android:textSize="13sp"
                        android:textColor="@color/secondary_text" />

                    <TextView
                        android:id="@+id/satelliteList"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textSize="11sp"
                        android:textColor="@color/secondary_text"
                        android:maxLines="6"
                        android:ellipsize="end" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 综合辐射评估 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/overallCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/overall_radiation"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_text" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical">

                        <com.signalmontor.app.view.RadiationGaugeView
                            android:id="@+id/overallRadiationGauge"
                            android:layout_width="100dp"
                            android:layout_height="100dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:id="@+id/overallRadiationLevel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="22sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/overallPercent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="占安全限值: --%"
                                android:textSize="13sp"
                                android:textColor="@color/secondary_text"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/overallRecommendation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/overall_recommendation"
                        android:textSize="13sp"
                        android:textColor="@color/secondary_text"
                        android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 辐射安全标准 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/standardsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="辐射安全标准与参考"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_text" />

                    <LinearLayout
                        android:id="@+id/standardsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="10dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginTop="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="常见设备辐射水平"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_text"
                        android:layout_marginTop="10dp" />

                    <LinearLayout
                        android:id="@+id/deviceLevelsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Button
                android:id="@+id/refreshBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="刷新信号"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/permissionBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="请求必要权限"
                android:visibility="gone"
                android:layout_marginBottom="12dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
